{
  "manifest_version": 3,
  "name": "Autodarts Session Coach",
  "version": "0.6.13",
  "description": "Leg-based match coach overlay for play.autodarts.io with history, goals, training plans and a checkout advisor.",
  "permissions": [
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "https://play.autodarts.io/*"
  ],
  "action": {
    "default_title": "Autodarts Session Coach",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://play.autodarts.io/*"
      ],
      "js": [
        "shared.js",
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "page-bridge.js",
        "coach.html",
        "coach.css",
        "coach.js",
        "shared.js"
      ],
      "matches": [
        "https://play.autodarts.io/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}